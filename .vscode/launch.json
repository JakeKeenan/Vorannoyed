      ],
      "cwd": "${workspaceFolder}/Vorannoyed",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "justMyCode": true
    }
  ],
  "inputs": [
    {
      "id": "scenarioName",
      "type": "promptString",
      "description": "Vorannoyed SVG scenario name",
      "default": "trapezoid"
    }
  ]
}
